Include ~/.orbstack/ssh/config

Host *
  ForwardX11 no
  IdentityAgent ~/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/socket.ssh

Host dev-matcha
  User ubuntu
  ForwardAgent yes

Host ubuntu-x86
  HostName localhost
  Port 32222
  User andre@ubuntu-x86
  ForwardAgent yes
  IdentityFile ~/.orbstack/ssh/id_ed25519

Host ubuntu
  HostName localhost
  Port 32222
  User default
  ForwardAgent yes
  IdentityFile ~/.orbstack/ssh/id_ed25519

Host andre-tee-vm
  HostName 157.56.163.87
  User lunaluser
  ForwardAgent yes
  # RemoteCommand sudo -E su

Host ig-11
  HostName ig-11
  User ig-11\andre
  RequestTTY force
  RemoteCommand pwsh

# Home
Host home
  Port 2222
  HostName  home.arko.me
  User andre
  RequestTTY force
  RemoteCommand ~/.bin/tmux-named main

# Home plus VNC and SMB forwarded to localhost
Host homefwd
  Port 2222
  HostName  home.arko.me
  User andre
  # Screen sharing / VNC
  LocalForward  5901 localhost:5900
  # SMB on localhost:4455
  LocalForward  4455 localhost:445
  # Get a TTY for tmux
  RequestTTY force
  # Join the main tmux session
  RemoteCommand ~/.bin/tmux-named main

# AWS
Host *.compute-1.amazonaws.com
  StrictHostKeyChecking no

Host github.com
  HostName ssh.github.com
  Port 443
